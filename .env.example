# Vorlage für die lokale Konfiguration.
# Kopiere diese Datei zu ".env" und trage deine echten Werte ein.
# Die ".env" wird NICHT nach GitHub hochgeladen (siehe .gitignore).

# --- Allgemein ---
EVENT_NAME=For Those Who Can't
LAP_DISTANCE_KM=1.0

# Spendenziel in Euro (Fortschrittsleiste auf der Website). Jederzeit ohne
# Code-Änderung anpassbar -- einfach hier bzw. bei Render neu setzen.
DONATION_GOAL=25000

# Öffentlich erreichbare Adresse (für Links in E-Mails/Tickets).
# Lokal so lassen; in Produktion die echte Domain eintragen.
PUBLIC_BASE_URL=http://localhost:8000

# Admin-Passwort für die Zurücksetzen-Seite (/api/admin). Selbst ausdenken,
# etwas Langes/Zufälliges. Leer = Zurücksetzen ist deaktiviert.
# ADMIN_TOKEN=

# Fehler-Monitoring (optional). Kostenlosen DSN auf sentry.io erstellen und hier
# bzw. bei Render eintragen -- dann werden Server-Fehler automatisch erfasst und
# du bekommst eine E-Mail. Leer = Monitoring aus.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# Datenbank. Leer lassen = lokale SQLite-Datei (database.db).
# Für dauerhaften Betrieb eine echte Postgres-DB (z. B. Neon, kostenlos):
#   Connection-String aus dem Neon-Dashboard kopieren, sieht etwa so aus:
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require

# --- E-Mail: Resend (EMPFOHLEN, HTTP-API) ---
# Funktioniert auch auf Render (SMTP wird dort im Gratis-Plan blockiert).
#   1) Account auf resend.com anlegen
#   2) API Keys -> Create API Key -> Wert kopieren
#   3) Hier (bzw. bei Render) als RESEND_API_KEY eintragen
# Ohne eigene Domain als Absender "onboarding@resend.dev" nutzen -- dann gehen
# Mails aber nur an die eigene Resend-Konto-Adresse (Testmodus). Für Mails an
# alle Teilnehmer:innen später eine eigene Domain in Resend verifizieren.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=For Those Who Can't <onboarding@resend.dev>

# --- E-Mail: SMTP (Fallback, z. B. Gmail) ---
# ACHTUNG: Auf Render (Gratis) blockiert -- nur lokal/eigener Server sinnvoll.
# Ohne E-Mail-Konfiguration läuft der Dev-Modus (Mail landet als HTML-Datei
# unter backend/dev_emails/).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=deinname@gmail.com
# SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# SMTP_FROM=deinname@gmail.com
# SMTP_FROM_NAME=For Those Who Can't

# --- Apple Wallet (optional, braucht Apple Developer Account) ---
# APPLE_TEAM_ID=
# APPLE_PASS_TYPE_ID=pass.com.deinedomain.ftwc
# APPLE_WWDR_CERT_PATH=certs/wwdr.pem
# APPLE_SIGNER_CERT_PATH=certs/pass_cert.pem
# APPLE_SIGNER_KEY_PATH=certs/pass_key.pem
# APPLE_SIGNER_KEY_PASSWORD=

# --- Google Wallet (optional, kostenlos) ---
# GOOGLE_WALLET_ISSUER_ID=
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=certs/service-account.json
